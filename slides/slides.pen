                  "name": "s3hackstep2",
                  "fill": "#FFFFFF",
                  "textGrowth": "fixed-width",
                  "width": 318,
                  "content": "2. Check for addJavascriptInterface() in source",
                  "lineHeight": 1.4,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "ILpyf",
                  "name": "s3hackstep3",
                  "fill": "#FF6B6B",
                  "textGrowth": "fixed-width",
                  "width": 318,
                  "content": "3. Craft malicious HTML page that calls:\n   Android.readFile(\"/data/data/...\")",
                  "lineHeight": 1.4,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 12,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "4aefV",
                  "name": "s3hackstep4",
                  "fill": "#FFFFFF",
                  "textGrowth": "fixed-width",
                  "width": 318,
                  "content": "4. Host page → send deep link → app loads it\n   → JS executes → native code runs",
                  "lineHeight": 1.4,
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 12,
                  "fontWeight": "normal"
                }
              ]
            },
